# =====================================================================
# ARES — environment configuration (copy to .env and fill in)
# =====================================================================
# Everything Entra/Graph-related comes from your app registration in
# Entra ID (Azure portal → App registrations → ARES).
# ---------------------------------------------------------------------

# ---- Entra ID (Azure AD) ----------------------------------------------------
# Directory (tenant) ID of your Entra tenant.
ARES_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# Application (client) ID of the ARES app registration (the API/daemon app).
ARES_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Client secret (Certificates & secrets → New client secret).
# For production prefer a certificate; secret is fine for an on-prem pilot.
ARES_ENTRA_CLIENT_SECRET=replace-with-client-secret
# Audience the API expects on incoming access tokens. Usually api://<client-id>
# or the client-id itself, depending on how you exposed the API scope.
ARES_ENTRA_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000

# ---- Microsoft Graph — email (application permissions) ----------------------
# Shared mailbox that ARES releases notifications from. Requires Mail.Send
# (Application) consent AND an ApplicationAccessPolicy scoping the app to this
# mailbox (see README §Entra setup).
ARES_MAIL_SENDER=global.it.communications@birgma.com
# Save a copy of each release to the sender's Sent Items.
ARES_MAIL_SAVE_TO_SENT=true

# ---- Microsoft Graph — Teams war room (application permissions) --------------
# Object id of the Team (group) under which ARES creates incident war-room
# channels. Requires Channel.Create + ChannelMessage.Send (Application). Leave
# blank to disable Teams provisioning. See README §Teams.
ARES_TEAMS_TEAM_ID=

# ---- Frontend (Vite) — public, baked in at build time -----------------------
# These are exposed to the browser; only non-secret values belong here.
ARES_WEB_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ARES_WEB_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# Scope the SPA requests for the ARES API (matches the exposed API scope).
ARES_WEB_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
# Where the browser reaches the API (through the web container's nginx proxy).
ARES_WEB_API_BASE=/api

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=ares
POSTGRES_PASSWORD=ares-local-dev-change-me
POSTGRES_DB=ares

# ---- Runtime toggles --------------------------------------------------------
# When true the API allows an unauthenticated "demo" identity so you can run
# the whole stack on-prem before Entra is wired up. Set to false once Entra
# sign-in works. NEVER run with this true in a real environment.
ARES_ALLOW_DEMO_AUTH=true
